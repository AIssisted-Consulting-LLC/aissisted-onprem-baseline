# Example environment template
# Do not commit real secrets.

# Core runtime
APP_ENV=production
LOG_LEVEL=info
TIMEZONE=America/New_York

# Gateway / orchestrator
GATEWAY_BIND=127.0.0.1
GATEWAY_PORT=18789
GATEWAY_AUTH_TOKEN=replace-with-long-random-token

# Model providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Local model endpoint example
LOCAL_MODEL_BASE_URL=http://127.0.0.1:11434
LOCAL_MODEL_NAME=

# Retrieval
VECTOR_DB_URL=
EMBEDDING_MODEL=
RAG_CORPUS_PATH=/srv/agent-data/corpus
RAG_INDEX_PATH=/srv/agent-data/index

# Logging
LOG_DIR=/var/log/agent-stack
METRICS_BIND=127.0.0.1
METRICS_PORT=9090

# Backups
BACKUP_DIR=/srv/agent-backups
SNAPSHOT_RETENTION_DAYS=14

# Remote admin
SSH_ADMIN_HOST=
TAILNET_NAME=
