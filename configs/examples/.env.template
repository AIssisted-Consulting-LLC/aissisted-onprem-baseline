# Example environment variables for an on-prem agent deployment
# Template only. Do not commit real secrets.

# Core routing
DEFAULT_MODEL_ROUTE=local-general
REASONING_MODEL_ROUTE=hosted-reasoning
EMBEDDING_MODEL_ROUTE=local-embeddings

# Gateway binding
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8080
GATEWAY_AUTH_REQUIRED=true

# Remote access
ENABLE_PUBLIC_INGRESS=false
REMOTE_ACCESS_MODE=ssh-tunnel
TAILNET_ENABLED=false

# Tool policy
EXEC_TOOL_ENABLED=false
BROWSER_TOOL_ENABLED=false
DEVICE_CONTROL_ENABLED=false
REQUIRE_APPROVAL_FOR_DANGEROUS_ACTIONS=true
WORKSPACE_ROOT=/srv/agent/workspace
TEMP_ROOT=/srv/agent/tmp

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_RETENTION_DAYS=14
LOG_PROMPTS=false
LOG_TOOL_ARGS=true
LOG_TOOL_OUTPUTS=false
LOG_CORRELATION_IDS=true

# RAG
RAG_ENABLED=true
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_REQUIRE_SOURCE_METADATA=true
RAG_INDEX_REBUILD_MODE=manual

# Secrets
SECRETS_BACKEND=os-keychain
SHORT_LIVED_TOKENS_ONLY=true

# Backups / rollback
SNAPSHOT_BEFORE_DEPLOY=true
CONFIG_BACKUP_PATH=/srv/agent/backups/config
DOC_BACKUP_PATH=/srv/agent/backups/docs

# Channels
ENABLE_DISCORD=false
ENABLE_TELEGRAM=false
ENABLE_WHATSAPP=false

# Notes:
# - Keep the gateway bound to loopback unless you have a strong reason not to.
# - Inject secrets at runtime from a secret store instead of putting them in this file.
# - Turn tools on one by one, with approval gates and logging in place.
